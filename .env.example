# Google Maps API Key
# Get your key from: https://console.cloud.google.com/
# ⚠️ IMPORTANT: Restrict the key to:
#   - JavaScript Maps API only
#   - Your authorized domains (e.g., chadj.github.io, localhost)
GOOGLE_MAPS_API_KEY=YOUR_API_KEY_HERE

# OAuth Configuration (if using Strava integration)
STRAVA_CLIENT_ID=YOUR_STRAVA_CLIENT_ID
STRAVA_CLIENT_SECRET=YOUR_STRAVA_CLIENT_SECRET
